# Frontend environment variables (Next.js)
# Only NEXT_PUBLIC_* vars are exposed to the browser. Do not put secrets here.

# Base URL of the backend API
NEXT_PUBLIC_API_BASE_URL=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX).
# Leave empty to disable GTM; the app loads it only when this is set.
NEXT_PUBLIC_GTM_ID=

# Google OAuth Web client ID for "Continue with Google" (Google Identity Services).
# Public by design (not a secret). Leave empty to hide the Google button entirely.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
